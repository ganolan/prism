{
  "name": "prism",
  "version": "0.1.0",
  "description": "Student dashboard — local-first Schoology + PowerSchool viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "test:api": "node test-api.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "csv-parse": "^5.6.0",
    "js-yaml": "^4.1.0",
    "oauth-1.0a": "^2.2.6"
  }
}
